generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               Role      @default(ADMIN)
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  clients            Client[]

  @@map("users")
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

model Client {
  id             String       @id @default(cuid())
  name           String
  industry       String
  contactName    String?
  contactEmail   String?
  website        String?
  timezone       String       @default("Asia/Karachi")
  marketingGoals String?
  status         ClientStatus @default(ACTIVE)
  ownerId        String
  owner          User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  brandKit       BrandKit?
  campaigns      Campaign[]
  @@index([ownerId, status])
  @@map("clients")
}

enum CampaignStatus {
  DRAFT
  GENERATED
  APPROVED
}
enum PostPlatform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  GOOGLE_BUSINESS
}

model Campaign {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brief     String
  days      Int            @default(30)
  status    CampaignStatus @default(DRAFT)
  posts     ContentPost[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  @@index([clientId, createdAt])
  @@map("campaigns")
}

model ContentPost {
  id          String       @id @default(cuid())
  campaignId  String
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform    PostPlatform
  title       String
  caption     String
  hashtags    String[]     @default([])
  imagePrompt String?
  scheduledFor DateTime?
  createdAt   DateTime     @default(now())
  @@index([campaignId])
  @@map("content_posts")
}

model BrandKit {
  id             String   @id @default(cuid())
  clientId       String   @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  primaryColor   String   @default("#176b4b")
  secondaryColor String   @default("#dfff9e")
  accentColor    String   @default("#13201c")
  headingFont    String   @default("Inter")
  bodyFont       String   @default("Inter")
  toneOfVoice    String?
  targetAudience String?
  brandStory     String?
  products       String[] @default([])
  services       String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("brand_kits")
}
